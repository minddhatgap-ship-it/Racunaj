{
  "expo": {
    "name": "onspace-app",
    "slug": "onspace-app",
    "version": "1.0.0",
    "extra": {
      "eas": {
        "projectId": "c98c4e32-dec6-4526-bb16-38f3abb7c59a"
      }
    },
    "cli": {
      "appVersionSource": "remote"
    },
    "orientation": "portrait",
    "icon": "./assets/images/logo.png",
    "scheme": "onspaceapp",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.onspace.racunovodstvo",
      "infoPlist": {
        "NSBluetoothAlwaysUsageDescription": "Ta aplikacija potrebuje Bluetooth dostop za povezavo s POS tiskalniki in tiskanje računov.",
        "NSBluetoothPeripheralUsageDescription": "Ta aplikacija potrebuje Bluetooth dostop za komunikacijo s tiskalniki."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/logo.png",
        "backgroundColor": "#ffffff"
      },
      "edgeToEdgeEnabled": true,
      "permissions": [
        "BLUETOOTH",
        "BLUETOOTH_ADMIN",
        "BLUETOOTH_SCAN",
        "BLUETOOTH_CONNECT",
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION"
      ],
      "package": "com.onspace.racunovodstvo"
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/logo.png"
    },
    "plugins": [
      "expo-router",
      "expo-web-browser",
      [
        "expo-build-properties",
        {
          "android": {
            "minSdkVersion": 24,
            "targetSdkVersion": 34,
            "compileSdkVersion": 34
          },
          "ios": {
            "deploymentTarget": "15.4"
          }
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
